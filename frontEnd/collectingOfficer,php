$pdo = getDBConnection();

// Handle AJAX requests
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_SERVER['HTTP_X_REQUESTED_WITH'])) {
    header('Content-Type: application/json');
    
    $action = $_POST['action'] ?? '';
    
    switch($action) {
        case 'add_tortoise':
            $result = addTortoise($pdo, $_POST);
            echo json_encode($result);
            break;
        case 'update_tortoise':
            $result = updateTortoise($pdo, $_POST);
            echo json_encode($result);
            break;
        case 'delete_tortoise':
            $result = deleteTortoise($pdo, $_POST['tortoise_id']);
            echo json_encode($result);
            break;
        case 'add_transport':
            $result = addTransport($pdo, $_POST);
            echo json_encode($result);
            break;
        case 'update_transport':
            $result = updateTransport($pdo, $_POST);
            echo json_encode($result);
            break;
        case 'delete_transport':
            $result = deleteTransport($pdo, $_POST['transport_id']);
            echo json_encode($result);
            break;
        default:
            echo json_encode(['success' => false, 'message' => 'Invalid action']);
    }
    exit;
}

// Fetch initial data
$tortoises = getTortoises($pdo);
$transports = getTransports($pdo);
$stats = getDashboardStats($pdo);

// CRUD Functions
function getTortoises($pdo) {
    $stmt = $pdo->query("SELECT * FROM tortoises ORDER BY collection_date DESC");
    return $stmt->fetchAll(PDO::FETCH_ASSOC);
}

function getTransports($pdo) {
    $stmt = $pdo->query("SELECT * FROM transport_logs ORDER BY departure_date DESC");
    return $stmt->fetchAll(PDO::FETCH_ASSOC);
}

function getDashboardStats($pdo) {
    $stats = [];
    
    $stmt = $pdo->query("SELECT COUNT(*) as total FROM tortoises");
    $stats['total_tortoises'] = $stmt->fetch(PDO::FETCH_ASSOC)['total'];
    
    $stmt = $pdo->query("SELECT COUNT(*) as count FROM tortoises WHERE MONTH(collection_date) = MONTH(CURDATE()) AND YEAR(collection_date) = YEAR(CURDATE())");
    $stats['monthly_collections'] = $stmt->fetch(PDO::FETCH_ASSOC)['count'];
    
    $stmt = $pdo->query("SELECT COUNT(*) as active FROM transport_logs WHERE status IN ('Pending', 'Ongoing')");
    $stats['active_transports'] = $stmt->fetch(PDO::FETCH_ASSOC)['active'];
    
    return $stats;
}

function addTortoise($pdo, $data) {
    try {
        $sql = "INSERT INTO tortoises (tortoise_id, species, age, source_type, collection_location, collection_date, health_status, notes, collected_by) 
                VALUES (:tortoise_id, :species, :age, :source_type, :collection_location, :collection_date, :health_status, :notes, :collected_by)";
        
        $stmt = $pdo->prepare($sql);
        $result = $stmt->execute([
            ':tortoise_id' => $data['tortoise_id'],
            ':species' => $data['species'],
            ':age' => !empty($data['age']) ? $data['age'] : null,
            ':source_type' => $data['source_type'],
            ':collection_location' => $data['collection_location'],
            ':collection_date' => $data['collection_date'],
            ':health_status' => $data['health_status'],
            ':notes' => $data['notes'] ?? '',
            ':collected_by' => $_SESSION['user_id'] ?? 'collecting_officer'
        ]);
        
        if ($result) {
            return ['success' => true, 'message' => 'Tortoise added successfully'];
        }
        return ['success' => false, 'message' => 'Failed to add tortoise'];
    } catch (PDOException $e) {
        return ['success' => false, 'message' => 'Database error: ' . $e->getMessage()];
    }
}

function updateTortoise($pdo, $data) {
    try {
        $sql = "UPDATE tortoises SET 
                species = :species,
                age = :age,
                source_type = :source_type,
                collection_location = :collection_location,
                collection_date = :collection_date,
                health_status = :health_status,
                notes = :notes
                WHERE tortoise_id = :tortoise_id";
        
        $stmt = $pdo->prepare($sql);
        $result = $stmt->execute([
            ':species' => $data['species'],
            ':age' => !empty($data['age']) ? $data['age'] : null,
            ':source_type' => $data['source_type'],
            ':collection_location' => $data['collection_location'],
            ':collection_date' => $data['collection_date'],
            ':health_status' => $data['health_status'],
            ':notes' => $data['notes'] ?? '',
            ':tortoise_id' => $data['tortoise_id']
        ]);
        
        return ['success' => $result, 'message' => $result ? 'Tortoise updated successfully' : 'Update failed'];
    } catch (PDOException $e) {
        return ['success' => false, 'message' => 'Database error: ' . $e->getMessage()];
    }
}

function deleteTortoise($pdo, $tortoise_id) {
    try {
        $stmt = $pdo->prepare("DELETE FROM tortoises WHERE tortoise_id = :tortoise_id");
        $result = $stmt->execute([':tortoise_id' => $tortoise_id]);
        return ['success' => $result, 'message' => $result ? 'Tortoise deleted successfully' : 'Deletion failed'];
    } catch (PDOException $e) {
        return ['success' => false, 'message' => 'Database error: ' . $e->getMessage()];
    }
}

function addTransport($pdo, $data) {
    try {
        $sql = "INSERT INTO transport_logs (tortoise_id, vehicle, from_location, to_location, status, departure_date, notes) 
                VALUES (:tortoise_id, :vehicle, :from_location, :to_location, :status, :departure_date, :notes)";
        
        $stmt = $pdo->prepare($sql);
        $result = $stmt->execute([
            ':tortoise_id' => $data['tortoise_id'],
            ':vehicle' => $data['vehicle'],
            ':from_location' => $data['from_location'],
            ':to_location' => $data['to_location'],
            ':status' => $data['status'],
            ':departure_date' => $data['departure_date'],
            ':notes' => $data['notes'] ?? ''
        ]);
        
        return ['success' => $result, 'message' => $result ? 'Transport log added successfully' : 'Failed to add transport log'];
    } catch (PDOException $e) {
        return ['success' => false, 'message' => 'Database error: ' . $e->getMessage()];
    }
}

function updateTransport($pdo, $data) {
    try {
        $sql = "UPDATE transport_logs SET 
                vehicle = :vehicle,
                from_location = :from_location,
                to_location = :to_location,
                status = :status,
                departure_date = :departure_date,
                notes = :notes
                WHERE id = :transport_id";
        
        $stmt = $pdo->prepare($sql);
        $result = $stmt->execute([
            ':vehicle' => $data['vehicle'],
            ':from_location' => $data['from_location'],
            ':to_location' => $data['to_location'],
            ':status' => $data['status'],
            ':departure_date' => $data['departure_date'],
            ':notes' => $data['notes'] ?? '',
            ':transport_id' => $data['transport_id']
        ]);
        
        return ['success' => $result, 'message' => $result ? 'Transport updated successfully' : 'Update failed'];
    } catch (PDOException $e) {
        return ['success' => false, 'message' => 'Database error: ' . $e->getMessage()];
    }
}

function deleteTransport($pdo, $transport_id) {
    try {
        $stmt = $pdo->prepare("DELETE FROM transport_logs WHERE id = :transport_id");
        $result = $stmt->execute([':transport_id' => $transport_id]);
        return ['success' => $result, 'message' => $result ? 'Transport log deleted successfully' : 'Deletion failed'];
    } catch (PDOException $e) {
        return ['success' => false, 'message' => 'Database error: ' . $e->getMessage()];
    }
}

// Helper functions for badges
function getHealthBadge($status) {
    switch($status) {
        case 'Healthy':
            return '<span class="status good">Healthy</span>';
        case 'Weak':
            return '<span class="status warning">Weak</span>';
        case 'Injured':
            return '<span class="status critical">Injured</span>';
        default:
            return '<span class="status">' . $status . '</span>';
    }
}

function getTransportBadge($status) {
    switch($status) {
        case 'Completed':
            return '<span class="status good">Completed</span>';
        case 'Ongoing':
            return '<span class="status ongoing">Ongoing</span>';
        case 'Pending':
            return '<span class="status pending">Pending</span>';
        default:
            return '<span class="status">' . $status . '</span>';
    }
}
