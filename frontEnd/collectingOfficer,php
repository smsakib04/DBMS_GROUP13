<div id="toast" class="toast"></div>

<script>
function showToast(message, isError = false) {
    const toast = document.getElementById('toast');
    toast.textContent = message;
    toast.style.background = isError ? '#dc3545' : '#198754';
    toast.style.display = 'block';
    setTimeout(() => toast.style.display = 'none', 3000);
}

function openTab(tabName) {
    document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
    document.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
    document.getElementById(tabName).classList.add('active');
    event.target.classList.add('active');
}

function searchTable() {
    const input = document.getElementById('searchInput').value.toLowerCase();
    const rows = document.querySelectorAll('#tortoiseTable tbody tr');
    rows.forEach(row => {
        row.style.display = row.innerText.toLowerCase().includes(input) ? '' : 'none';
    });
}

function closeModal(modalId) {
    document.getElementById(modalId).style.display = 'none';
}

function editTortoise(tortoise) {
    document.getElementById('edit_tortoise_id').value = tortoise.tortoise_id;
    document.getElementById('edit_species').value = tortoise.species;
    document.getElementById('edit_age').value = tortoise.age;
    document.getElementById('edit_source_type').value = tortoise.source_type;
    document.getElementById('edit_location').value = tortoise.collection_location;
    document.getElementById('edit_date').value = tortoise.collection_date;
    document.getElementById('edit_health').value = tortoise.health_status;
    document.getElementById('edit_notes').value = tortoise.notes || '';
    document.getElementById('editModal').style.display = 'flex';
}

function deleteTortoise(tortoiseId) {
    if (confirm('Delete this tortoise record?')) {
        const formData = new FormData();
        formData.append('action', 'delete_tortoise');
        formData.append('tortoise_id', tortoiseId);
        fetch(window.location.href, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' }, body: formData })
            .then(r => r.json()).then(result => { showToast(result.message); if(result.success) setTimeout(() => location.reload(), 1000); });
    }
}

